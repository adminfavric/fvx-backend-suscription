# Docker Compose — nombre del proyecto (`docker compose ls`, etiqueta en Docker Desktop)
COMPOSE_PROJECT_NAME=fvx_backend

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Orígenes confiados para CSRF (Origin del SPA en métodos inseguros con auth por
# cookie). En DEBUG=True el settings ya trae los orígenes dev locales
# (localhost:4200/3000/8080), así que NO necesitas tocarlo en desarrollo.
# Producción (HTTPS detrás de nginx): declara aquí cada frontend, con https:// y
# sin barra final, separados por coma.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com
# DJANGO_USE_PROXY_HEADERS=True
DJANGO_SETTINGS_MODULE=core.settings

# Database
POSTGRES_DB=fvx_suscription_db
POSTGRES_USER=fvx_suscription_user
POSTGRES_PASSWORD=fvx_password_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (for caching and Celery)
REDIS_URL=redis://redis:6379/0

# ─── Celery (jobs async + tasks programadas) ──────────────────────────────────
# Defaults usan los DBs 0 y 1 del Redis del stack. Para entornos compartidos
# o multi-stack, apuntar a Redis externos.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Sentry (error tracking — opcional) ───────────────────────────────────────
# Vacío en dev → no envía nada. Setear DSN en staging/prod.
# SENTRY_DSN=https://<key>@<project>.ingest.sentry.io/<id>
# SENTRY_ENVIRONMENT=local        # local | staging | production
# SENTRY_TRACES_SAMPLE_RATE=0.1   # 10% de requests por default
# APP_VERSION=                    # CI lo setea con el SHA del build

# CORS (django-cors-headers)
# Default-deny: por defecto NO se abre a todos los orígenes; se usa la
# allow-list de CORS_ALLOWED_ORIGINS (abajo ya trae los puertos dev locales).
# Pon CORS_ALLOW_ALL_ORIGINS=True solo si de verdad necesitas abrir a cualquier
# dominio en dev local (no recomendado; con DEBUG=False el guardrail lo prohíbe).
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
# En producción rellena CORS_ALLOWED_ORIGINS con todos los frontends
# (https://app.tudominio.com,...). Solo aplica cuando CORS_ALLOW_ALL_ORIGINS=False.

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=60

# ─── API keys ─────────────────────────────────────────────────────────────────
# Marca/prefijo de las API keys generadas: formato <brand>.<prefix>.<secret>
# (p. ej. fvx.ab12….xyz…). Cada proyecto descendiente puede poner su propia
# marca. Solo letras/dígitos en minúscula. Default: fvx.
API_KEY_BRAND_PREFIX=fvx

# ─── Flow.cl (suscripciones / pagos) ──────────────────────────────────────────
# Credenciales del panel de comercio Flow → Configuración → API.
# FLOW_SANDBOX=True usa sandbox.flow.cl (pruebas con tarjetas de test); ponlo en
# False para producción (www.flow.cl). Deja FLOW_API_BASE vacío salvo override.
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_SANDBOX=True
FLOW_API_BASE=
# URLs públicas para el retorno del checkout de Flow (registro de tarjeta).
# PUBLIC_API_BASE_URL: a dónde Flow devuelve al cliente (este backend, accesible
# desde el navegador). FRONTEND_BASE_URL: a dónde redirigimos para mostrar el resultado.
PUBLIC_API_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:4201

# ─── Cookies de auth (JWT en HttpOnly cookies) ────────────────────────────────
# Política recomendada por entorno (frontend + backend en misma raíz de dominio):
#   dev (DEBUG=True): Secure=False, SameSite=Lax, Domain vacío.
#   prod misma raíz (api.ejemplo.cl + app.ejemplo.cl): Secure=True, SameSite=Strict, Domain=.ejemplo.cl
#   prod cross-site (cliente con su propio dominio → tu API): Secure=True, SameSite=None.
#
# Si DEBUG=False y AUTH_COOKIE_SAMESITE=None sin Secure=True, settings.py rompe el startup
# (regla obligatoria de browsers).
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=Strict
# AUTH_COOKIE_DOMAIN=.ejemplo.cl

# Social login (Google / Apple / Microsoft id_token → mismo par JWT que SimpleJWT)
# Activar por separado. Si está en false, el POST del proveedor responde 403.
# El front muestra cada botón solo si su flag está ON y su client_id presente.
SOCIAL_AUTH_GOOGLE_ENABLED=False
SOCIAL_AUTH_APPLE_ENABLED=False
SOCIAL_AUTH_MICROSOFT_ENABLED=False
# Google: Client ID de OAuth 2.0 tipo "Web" (debe coincidir con el aud del id_token GIS)
GOOGLE_OAUTH_CLIENT_ID=
# Apple: Services ID (web). Team ID / Key ID / .p8 solo hacen falta si el backend intercambia authorization code
APPLE_CLIENT_ID=
# Microsoft Entra ID: Application (client) ID del registro de app (SPA). El front lo usa con MSAL.
MICROSOFT_OAUTH_CLIENT_ID=
# Tenant: 'common' (multi-tenant + cuentas personales), 'organizations', 'consumers',
# o un GUID/dominio concreto para restringir a tu organización.
MICROSOFT_OAUTH_TENANT_ID=common

# ─── Email transaccional (notifications/) ─────────────────────────────────────
# Ver fvx-backend/docs/email.md. Adapter pattern provider-agnostic.
# Valores: smtp | ses | console
NOTIFICATIONS_EMAIL_ADAPTER=smtp
DEFAULT_FROM_EMAIL=no-reply@local.test

# SMTP (Mailpit local o cualquier proveedor SMTP genérico).
# En docker-compose Mailpit corre como servicio `mailpit` en la red interna →
# EMAIL_HOST=mailpit. Desde el host (manage.py shell directo): EMAIL_HOST=localhost.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Puerto HOST de la UI web de Mailpit (docker-compose la publica como
# ${MAILPIT_UI_PORT}:8025). install.sh lo pregunta para que dos proyectos en la
# misma máquina no choquen. El SMTP (1025) NO se publica: es solo intra-red.
MAILPIT_UI_PORT=8025

# ─── Amazon SES (NOTIFICATIONS_EMAIL_ADAPTER=ses) ─────────────────────────────
# Solo si despliegas a staging/prod con SES. Ver docs/email.md §14 para el setup
# AWS (DKIM + MAIL FROM + DMARC + salida de sandbox + configuration set + SNS).
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# AWS_SES_REGION_NAME=us-east-1
# AWS_SES_CONFIGURATION_SET=main
# NOTIFICATIONS_PERSIST_BODY=False    # True = persistir HTML completo (mayor peso/privacidad)

# Language
LANGUAGE_CODE=es
TIME_ZONE=America/Santiago

# Media and Static
MEDIA_URL=/media/
STATIC_URL=/static/

# ─── Storage (uploads) ────────────────────────────────────────────────────────
# Switch del backend para POST /api/v1/uploads/. El front no cambia; el binario
# va a Django y Django lo guarda con `default_storage`.
# Valores: local | s3 | gcs
STORAGE_BACKEND=local

# Tamaño máximo por archivo en bytes (default 25 MB). Archivos > 100 MB requieren
# también `client_max_body_size` en nginx y `--timeout` en gunicorn.
UPLOAD_MAX_BYTES=26214400

# Subdirectorio raíz dentro del bucket / MEDIA_ROOT. Útil cuando varios proyectos
# comparten el mismo bucket. Ejemplo: STORAGE_BUCKET_PREFIX=community →
#   S3:   s3://my-bucket/community/profiles/avatars/foo.png
#   GCS:  gs://my-bucket/community/profiles/avatars/foo.png
#   local: fvx-backend/media/community/profiles/avatars/foo.png  (y URL /media/community/...)
# Vacío (default) = sin prefijo (uploads en la raíz del bucket/MEDIA_ROOT).
STORAGE_BUCKET_PREFIX=

# ─── S3-compatible (STORAGE_BACKEND=s3) ───────────────────────────────────────
# Sirve para AWS S3 y proveedores compatibles: Backblaze B2, DigitalOcean Spaces,
# Wasabi, Cloudflare R2, MinIO… Solo cambia AWS_S3_ENDPOINT_URL.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=        # Solo para non-AWS, p. ej.
#                             #   Backblaze: https://s3.us-west-002.backblazeb2.com
#                             #   DO Spaces: https://nyc3.digitaloceanspaces.com
#                             #   Wasabi:    https://s3.wasabisys.com
#                             #   R2:        https://<accountid>.r2.cloudflarestorage.com
# AWS_DEFAULT_ACL=public-read # Omitir si el bucket ya es público y no acepta ACLs por objeto
# AWS_QUERYSTRING_AUTH=False  # True si quieres URLs firmadas para LECTURA

# ─── Google Cloud Storage (STORAGE_BACKEND=gcs) ───────────────────────────────
# Los SDKs de GCS YA vienen instalados (django-storages[google]). Para usarlo:
# pon STORAGE_BACKEND=gcs y descomenta lo de abajo + deja el JSON del service
# account en fvx-backend/ (se monta en /app dentro del contenedor; gitignoreado).
# GS_BUCKET_NAME=
# GS_PROJECT_ID=
# GS_DEFAULT_ACL=publicRead   # Omitir si el bucket es uniform-bucket-level-access
# GS_QUERYSTRING_AUTH=False
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcs-service-account.json
